# ---- Build outputs ----------------------------------------------------------
# .NET build artifacts (generated by `dotnet build` / `dotnet publish`).
bin/
obj/
out/
*.user
*.suo

# The sample/ and fixture projects all build to bin/ obj/ out/ above, so the
# wildcard rules above cover them.

# ---- Generated test artifacts ----------------------------------------------
# Dump files (large; regenerated by tests/fixtures/build-and-dump.sh).
dumps/
tests/dumps/

# Per-fixture run artifacts.
tests/fixtures/*/run.stdout
tests/fixtures/*/run.stderr
tests/fixtures/*/*.dmp

# ---- Tool / editor noise ---------------------------------------------------
.vs/
.vscode/
.idea/
*.swp
*.bak
*~
.DS_Store
Thumbs.db

# ---- Local Claude Code state ----------------------------------------------
.claude/
